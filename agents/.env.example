# InvestiSwarm Agent Pipeline - Environment Variables
# Copy this file to .env and fill in your API keys

# Set to "true" to use mock data instead of live API calls
MOCK_DATA=true

# Finnhub API key (https://finnhub.io/dashboard)
# Used by: News agent (headlines), Alt Assets agent (commodity prices)
# Free tier: 60 requests/minute
FINNHUB_API_KEY=your_finnhub_api_key_here

# Google Gemini API key (https://aistudio.google.com/apikey)
# Used by: Orchestrator agent (report synthesis)
GEMINI_API_KEY=your_gemini_api_key_here
